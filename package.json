{
  "name": "impexlink",
  "version": "1.0.0",
  "private": true,
  "main": "backend/src/index.js",
  "scripts": {
    "start": "node backend/src/index.js",
    "dev": "node --watch backend/src/index.js",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build": "npm run prisma:generate && vite build --config frontend/vite.config.ts",
    "build:dev": "vite build --mode development --config frontend/vite.config.ts",
    "lint": "eslint --config frontend/eslint.config.mjs frontend/src",
    "test": "vitest run --config frontend/vitest.config.ts",
    "test:watch": "vitest --config frontend/vitest.config.ts",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema backend/prisma/schema.prisma",
    "seed": "node backend/prisma/seed.js"
  },
